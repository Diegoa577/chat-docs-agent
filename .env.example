# Required: at least one LLM provider API key
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# Active providers (aligned with the docker-compose default)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=bge

# Optional: fallback providers used when the primary fails after retries
# (must be different from the primary and have a valid API key configured)
# LLM_FALLBACK_PROVIDER=gemini
# EMBEDDING_FALLBACK_PROVIDER=openai

# Optional: select a specific model from the catalog (backend/models.yaml).
# If omitted, the first model for the selected provider is used.
# LLM_MODEL=gpt-5.4

# Optional: path to the LLM model catalog file.
# MODELS_CATALOG_PATH=models.yaml

# Optional embedding model overrides
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# BGE_MODEL_NAME=BAAI/bge-small-en-v1.5

# Optional RAG tuning (defaults shown)
# RETRIEVAL_TOP_K=5          # chunks injected into the prompt
# HYBRID_ALPHA=0.5           # 0 = pure vector, 1 = pure keyword
# CHUNK_SIZE=512             # words per chunk
# CHUNK_OVERLAP=50           # words of overlap between chunks
# MAX_UPLOAD_SIZE_MB=50

# Local development (overridden by docker-compose.yml)
# DATABASE_URL=postgresql+asyncpg://cda_user:cda_password@localhost:5432/cda_db
# SYNC_DATABASE_URL=postgresql://cda_user:cda_password@localhost:5432/cda_db
# REDIS_URL=redis://localhost:6379/0

LOG_LEVEL=INFO
