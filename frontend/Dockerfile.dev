FROM node:20-alpine

WORKDIR /app

ENV NODE_ENV=development

# Prepare /app for the non-root node user that already exists in the image.
RUN chown node:node /app
USER node

COPY --chown=node:node package.json package-lock.json* ./
RUN npm install

COPY --chown=node:node . .

EXPOSE 3000

CMD ["npm", "run", "dev"]
